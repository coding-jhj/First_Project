# VoiceGuide 환경 변수 예시
# 복사 후 .env로 저장하고 값을 채워주세요

# ngrok 인증 토큰 (서버 외부 접근용)
NGROK_AUTH_TOKEN=

# 서버 포트 (기본값: 8000)
PORT=8000

# 서버 정밀 탐지 모델 (Android 온디바이스는 yolo11n.onnx 유지)
# 실시간 안내 기본형: Android YOLO11n + Server YOLO26s + Depth Anything V2
SERVER_YOLO_MODEL=yolo26s.pt

# Azure TTS (한국어 ko-KR-SoonBokNeural — 실시간 장애물 안내용)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=koreacentral

# Qwen3-TTS (HuggingFace Inference API — 자연스러운 음성, latency 3~8초)
# 실시간 장애물 안내 X, 비실시간(welcome 메시지 등) 용도 권장
# https://huggingface.co/Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
HF_TOKEN=
