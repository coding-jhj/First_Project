<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1A1A1A">

        <EditText
            android:id="@+id/etServerUrl"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="서버 URL  예) http://192.168.x.x:8000"
            android:inputType="textUri"
            android:padding="10dp"
            android:textSize="13sp"
            android:background="#1A1A1A"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888" />

        <Button
            android:id="@+id/btnServerMode"
            android:layout_width="88dp"
            android:layout_height="match_parent"
            android:text="서버 ON"
            android:textSize="14sp"
            android:backgroundTint="#1565C0" />

    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.camera.view.PreviewView
            android:id="@+id/previewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <com.voiceguide.BoundingBoxOverlay
            android:id="@+id/detectionOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/tvDebug"
            android:layout_width="190dp"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="48dp"
            android:layout_marginEnd="12dp"
            android:text="모드 : 확인 중\nFPS : -\n디코딩 : -\nYOLO : -\n후처리 : -\n전체 : -\n탐지수 : -"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="start"
            android:padding="8dp"
            android:background="#99000000"
            android:lineSpacingExtra="2dp" />

    </FrameLayout>

    <!-- 음성 안내 결과 -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="80dp"
        android:text="분석 시작 버튼을 누르세요"
        android:textSize="22sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:padding="16dp"
        android:background="#1A1A1A"
        android:lineSpacingMultiplier="1.4" />

    <TextView
        android:id="@+id/tvDetected"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="44dp"
        android:text="인식: 대기 중"
        android:textSize="15sp"
        android:textColor="#D6EFFF"
        android:gravity="center"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="#0B1B24"
        android:maxLines="3" />

    <!-- 모드 / 방향 상태 표시 -->
    <TextView
        android:id="@+id/tvMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="모드: 장애물  |  방향: 정면"
        android:textSize="13sp"
        android:textColor="#AAAAAA"
        android:gravity="center"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="#111111" />

    <!-- 버튼 행 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnToggle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:text="분석 시작"
            android:textSize="20sp"
            android:textStyle="bold"
            android:backgroundTint="#1565C0" />

        <Button
            android:id="@+id/btnStt"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="음성 명령"
            android:textSize="16sp"
            android:backgroundTint="#2E7D32" />

    </LinearLayout>

</LinearLayout>
