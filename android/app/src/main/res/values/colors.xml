<?xml version="1.0" encoding="utf-8"?>
<!-- VoiceGuide 다크 테마 색상 팔레트 — 야외/실내 모두 가시성 우선 설계 -->
<resources>
    <!-- 배경 색상 (다크 네이비 계열) -->
    <color name="vg_bg">#0A0F1E</color>       <!-- 앱 전체 최하단 배경 (거의 검정) -->
    <color name="vg_surface">#111827</color>   <!-- 카드·다이얼로그 표면 -->
    <color name="vg_panel">#1A2235</color>     <!-- 하단 패널 배경 -->

    <!-- 주요 액션 색상 (파란 계열) -->
    <color name="vg_primary">#2563EB</color>      <!-- 분석 시작/설정 버튼 -->
    <color name="vg_primary_dark">#1D4ED8</color> <!-- 버튼 눌림 상태 -->

    <!-- 마이크 버튼 상태 색상 -->
    <color name="vg_mic">#059669</color>        <!-- 대기 중 — 초록 -->
    <color name="vg_mic_active">#DC2626</color> <!-- 녹음 중 — 빨강 -->

    <!-- 텍스트 색상 계층 -->
    <color name="vg_text">#F1F5F9</color>      <!-- 주 안내 문장 (거의 흰색) -->
    <color name="vg_text_sub">#94A3B8</color>  <!-- 보조 정보 (모드·FPS) -->
    <color name="vg_text_hint">#475569</color> <!-- 힌트·비활성 텍스트 -->

    <!-- 구분선 / 오버레이 -->
    <color name="vg_divider">#1E293B</color>   <!-- 버튼 위 구분선 -->
    <color name="vg_overlay">#CC0A0F1E</color> <!-- 반투명 배경 오버레이 (CC = 80% 불투명) -->
</resources>
